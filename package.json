{
  "name": "@alt-javascript/jasypt",
  "version": "1.0.2",
  "description": "Jasypt (Java) clone for Node.js",
  "type": "module",
  "main": "index.js",
  "bin": {
    "jasypt": "./bin/jasypt.js"
  },
  "files": [
    "bin/",
    "digester.js",
    "encryptor.js",
    "index.js",
    "index.d.ts",
    "jasypt.js",
    "util.js"
  ],
  "scripts": {
    "test": "tap -j4 test/*",
    "ci": "tap -j4 test/* --coverage",
    "cov": "tap -j4 test/* --coverage-report=html",
    "benchmark": "node ./benchmark/jasypt.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alt-javascript/jasypt.git"
  },
  "keywords": [
    "jasypt",
    "pbewithmd5anddes",
    "crypto",
    "encrypt",
    "decrypt",
    "digest"
  ],
  "author": "Craig Parravicini",
  "contributors": [
    "Ricky泽阳 <mail@zhoumq.cn>"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/alt-javascript/jasypt/issues"
  },
  "homepage": "https://github.com/alt-javascript/jasypt#readme",
  "license": "MIT",
  "devDependencies": {
    "beautify-benchmark": "^0.2.4",
    "benchmark": "^2.1.4",
    "tap": "^21.6.2"
  },
  "tap": {
    "statements": 90,
    "branches": 65,
    "functions": 90,
    "lines": 90
  },
  "dependencies": {
    "commander": "^2.20.0",
    "des.js": "^1.1.0"
  }
}
